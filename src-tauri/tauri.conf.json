{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "케어닥",
  "version": "0.1.0",
  "identifier": "world.minhojan.carehome.tablet",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "케어닥",
        "width": 1280,
        "height": 800,
        "minWidth": 768,
        "minHeight": 500,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: ipc: 'unsafe-inline'; connect-src 'self' https://care.minhojan-world.site ws: wss:; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "store": {}
  }
}
